{
  "name": "astrocms",
  "private": true,
  "version": "0.0.0",
  "description": "CMS autohospedable para Astro + builder visual de bloques (monorepo)",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "e2e": "playwright test --config e2e/playwright.config.ts",
    "e2e:a11y": "playwright test --config e2e/playwright.a11y.config.ts",
    "e2e:builder": "playwright test --config e2e/playwright.builder.config.ts",
    "db:migrate": "turbo run db:migrate",
    "db:seed": "turbo run db:seed",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.48.0",
    "axe-core": "^4.10.0",
    "prettier": "^3.3.0",
    "turbo": "^2.1.0",
    "typescript": "^5.6.0"
  }
}
