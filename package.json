{
  "name": "astrocms",
  "private": true,
  "version": "0.0.0",
  "description": "CMS autohospedable para Astro + builder visual de bloques (monorepo)",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "db:migrate": "turbo run db:migrate",
    "db:seed": "turbo run db:seed",
    "boundaries": "depcruise --config .dependency-cruiser.cjs packages apps",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.6.0",
    "prettier": "^3.3.0"
  }
}
