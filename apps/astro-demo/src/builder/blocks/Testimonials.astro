---
interface Props {
  title?: string;
  quotes?: string;
}
const { title = "", quotes = "" } = Astro.props;
const attrs = Object.fromEntries(Object.entries(Astro.props).filter(([key]) => !["title", "quotes"].includes(key)));
function splitPair(line: string): { quote: string; author: string } {
  const index = line.indexOf("|");
  if (index === -1) return { quote: line.trim(), author: "" };
  return { quote: line.slice(0, index).trim(), author: line.slice(index + 1).trim() };
}
const testimonials = quotes.split("\n").map((line) => splitPair(line)).filter((item) => item.quote || item.author);
---
<section class="testimonials" {...attrs}>
  {title && <h2>{title}</h2>}
  <div class="testimonials__items">
    {testimonials.map((item) => (
      <blockquote class="testimonials__item">
        {item.quote && <p>{item.quote}</p>}
        {item.author && <cite>{item.author}</cite>}
      </blockquote>
    ))}
  </div>
</section>

<style>
  .testimonials { margin: 2rem 0; }
  .testimonials h2 { margin: 0 0 1rem; }
  .testimonials__items { display: grid; gap: 1rem; }
  .testimonials__item { margin: 0; padding: 1rem; border-left: 3px solid #111; background: #f7f7f7; }
  .testimonials__item p { margin: 0 0 0.5rem; line-height: 1.5; }
  .testimonials__item cite { font-style: normal; opacity: 0.7; }
</style>
