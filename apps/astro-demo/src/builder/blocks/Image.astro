---
import { mediaRefSchema } from "@astrocms/contracts";
import { getCms } from "../../lib/cms.js";

interface Props {
  media?: unknown;
  src?: string;
  alt?: string;
}
const { media, src = "", alt = "" } = Astro.props;
const attrs = Object.fromEntries(Object.entries(Astro.props).filter(([key]) => !["media", "src", "alt"].includes(key)));
let resolvedSrc = src;
let resolvedAlt = alt;
const parsedMedia = mediaRefSchema.safeParse(media);
if (parsedMedia.success) {
  try {
    const asset = await getCms().public.getMedia(parsedMedia.data.assetId);
    resolvedSrc = asset.url;
    if (!resolvedAlt) resolvedAlt = asset.alt ?? "";
  } catch {
    // El asset puede haber sido borrado o el CMS puede estar temporalmente inaccesible.
  }
}
---
<figure class="image-block" {...attrs}>
  {resolvedSrc ? <img src={resolvedSrc} alt={resolvedAlt} loading="lazy" /> : <div class="image-block__empty" aria-label={resolvedAlt} />}
</figure>

<style>
  .image-block { margin: 1rem 0; }
  .image-block img { display: block; width: 100%; height: auto; border-radius: 6px; }
  .image-block__empty { min-height: 12rem; border: 1px dashed #aaa; border-radius: 6px; background: #f6f6f6; }
</style>
