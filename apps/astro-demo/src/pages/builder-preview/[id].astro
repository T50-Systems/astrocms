---
import type { BuilderDocument, BuilderNode } from "@astrocms/contracts";
import BlockRenderer from "../../builder/BlockRenderer.astro";
import Layout from "../../layouts/Layout.astro";
import { getCms } from "../../lib/cms.ts";

const { id } = Astro.params;
const token = Astro.url.searchParams.get("token");
const channelId = Astro.url.searchParams.get("channelId") ?? "";
const adminOrigin = new URL(process.env.ADMIN_ORIGIN ?? "http://localhost:5173").origin;
const doc = id && token ? await getPreviewDocument(id, token) : null;

if (!doc || !channelId) {
  return new Response("Preview no autorizado", { status: 401 });
}

function collectNodeIds(node: BuilderNode): string[] {
  return [node.id, ...node.children.flatMap(collectNodeIds)];
}

async function getPreviewDocument(documentId: string, previewToken: string): Promise<BuilderDocument | null> {
  try {
    return await getCms().preview.getBuilderDocument(documentId, previewToken);
  } catch {
    return null;
  }
}

const renderedNodeIds = collectNodeIds(doc.root);
const previewConfigJson = JSON.stringify({ adminOrigin, channelId, documentId: doc.id, renderedNodeIds }).replace(/</g, "\\u003c");
---

<Layout title={doc.meta?.title ?? "Preview builder"}>
  <BlockRenderer node={doc.root} preview />
</Layout>

<script is:inline set:html={`window.__ASTROCMS_BUILDER_PREVIEW__ = ${previewConfigJson};`}></script>

<script>
  import {
    envelopeSchema,
    hostMessageSchema,
    PROTOCOL_VERSION,
    type BuilderNode,
    type GuestMessage,
  } from "@astrocms/contracts";
  import { REGISTERED_BLOCK_TYPES, type RegisteredBlockType } from "../../builder/block-types.ts";

  interface PreviewConfig {
    adminOrigin: string;
    channelId: string;
    documentId: string;
    renderedNodeIds: string[];
  }

  const previewConfig = (window as Window & { __ASTROCMS_BUILDER_PREVIEW__?: PreviewConfig }).__ASTROCMS_BUILDER_PREVIEW__;
  if (!previewConfig) throw new Error("Configuración de preview ausente");
  const { adminOrigin, channelId, documentId, renderedNodeIds } = previewConfig;

  const selectedAttr = "data-builder-selected";
  const messageBase = { protocol: PROTOCOL_VERSION, channelId, source: "guest" as const };

  let currentRenderToken = 0;
  let blockVersions: Record<string, number> = {};

  function send(message: GuestMessage) {
    window.parent.postMessage({ ...messageBase, message }, adminOrigin);
  }

  function escapeId(id: string) {
    return window.CSS && CSS.escape ? CSS.escape(id) : id.replace(/"/g, '\\"');
  }

  function nodeElement(nodeId: string): HTMLElement | null {
    return document.querySelector<HTMLElement>(`[data-builder-node-id="${escapeId(nodeId)}"]`);
  }

  function applyProps(nodeId: string, type: string, props: Record<string, unknown>) {
    const el = nodeElement(nodeId);
    if (!el) return;
    if (type === "site/hero") {
      const title = el.querySelector("h1");
      const desc = el.querySelector(".hero__desc");
      if (title && typeof props.title === "string") title.textContent = props.title;
      if (desc && typeof props.description === "string") desc.textContent = props.description;
      if (typeof props.alignment === "string") el.style.textAlign = props.alignment;
    } else if (type === "core/heading" || type === "core/paragraph") {
      if (typeof props.text === "string") el.textContent = props.text;
    } else if (type === "core/button") {
      if (typeof props.label === "string") el.textContent = props.label;
      if (typeof props.href === "string" && el instanceof HTMLAnchorElement) el.href = props.href;
    }
  }

  function walk(node: BuilderNode) {
    applyProps(node.id, node.type, node.props || {});
    for (const child of node.children || []) walk(child);
  }

  function reportErrors(root: BuilderNode) {
    const visit = (node: BuilderNode) => {
      if (!REGISTERED_BLOCK_TYPES.includes(node.type as RegisteredBlockType)) {
        send({ type: "guest/preview-error", nodeId: node.id, message: `Bloque no registrado: ${node.type}`, renderToken: currentRenderToken });
      } else {
        const expected = blockVersions[node.type];
        if (expected !== undefined && expected !== node.version) {
          send({ type: "guest/schema-mismatch", nodeId: node.id, blockType: node.type, expected, found: node.version, renderToken: currentRenderToken });
        }
      }
      for (const child of node.children ?? []) visit(child);
    };
    visit(root);
  }

  function selectNode(nodeId: string | null) {
    document.querySelectorAll(`[${selectedAttr}]`).forEach((el) => {
      el.removeAttribute(selectedAttr);
      if (el instanceof HTMLElement) {
        el.style.outline = "";
        el.style.outlineOffset = "";
      }
    });
    if (!nodeId) return;
    const el = nodeElement(nodeId);
    if (!el) return;
    el.setAttribute(selectedAttr, "true");
    el.style.outline = "2px solid #1d4ed8";
    el.style.outlineOffset = "2px";
  }

  window.addEventListener("message", (event: MessageEvent<unknown>) => {
    if (event.origin !== adminOrigin) return;
    const envelope = envelopeSchema.safeParse(event.data);
    if (!envelope.success || envelope.data.channelId !== channelId || envelope.data.source !== "host") return;
    const parsed = hostMessageSchema.safeParse(envelope.data.message);
    if (!parsed.success) return;
    const message = parsed.data;
    if (message.type === "host/ready") blockVersions = message.blockVersions;
    if (message.type === "host/document-updated") {
      currentRenderToken = message.renderToken;
      walk(message.document.root);
      reportErrors(message.document.root);
    }
    if (message.type === "host/node-props-updated") {
      const el = nodeElement(message.nodeId);
      applyProps(message.nodeId, el?.dataset["builderType"] ?? "", message.props);
    }
    if (message.type === "host/select-node") selectNode(message.nodeId);
    if (message.type === "host/set-breakpoint") document.documentElement.dataset.builderBreakpoint = message.breakpoint;
    if (message.type === "host/reload-preview") window.location.reload();
  });

  document.addEventListener("click", (event: MouseEvent) => {
    const target = event.target instanceof Element ? event.target.closest("[data-builder-node-id]") : null;
    if (!target) return;
    event.preventDefault();
    event.stopPropagation();
    const nodeId = target.getAttribute("data-builder-node-id");
    if (nodeId) send({ type: "guest/node-selected", nodeId });
  });

  send({ type: "guest/preview-ready", documentId, renderedNodeIds });
</script>
