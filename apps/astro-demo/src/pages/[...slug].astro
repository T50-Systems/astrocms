---
import Layout from "../layouts/Layout.astro";
import { getCms } from "../lib/cms.ts";
import BlockRenderer from "../builder/BlockRenderer.astro";

// Catch-all SSR: resuelve la página publicada por slug. '/' cuando no hay segmento.
const slugParam = Astro.params.slug;
const slug = "/" + (slugParam ?? "");
const page = await getCms().public.getPageBySlug(slug);

if (!page) {
  return new Response("Página no encontrada", { status: 404 });
}

// Páginas construidas con el builder visual: se renderizan a partir del árbol
// de bloques publicado, no del campo `data.body` (propio del editor de texto).
const builderDoc =
  page.editorType === "builder" && page.builderDocumentId
    ? await getCms().public.getBuilderDocument(page.builderDocumentId)
    : null;

const body = typeof page.data?.body === "string" ? page.data.body : undefined;
---

<Layout title={page.seo?.title ?? page.title} description={page.seo?.description}>
  {
    builderDoc ? (
      <BlockRenderer node={builderDoc.root} />
    ) : (
      <article>
        <h1>{page.title}</h1>
        {body && <p>{body}</p>}
        {!body && <p><em>Esta página aún no tiene contenido de cuerpo.</em></p>}
      </article>
    )
  }
</Layout>
