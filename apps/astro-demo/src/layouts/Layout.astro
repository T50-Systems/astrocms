---
import NavMenu from "../components/NavMenu.astro";
import { getMenu, getSiteSettings, getDesignTokenVars } from "../lib/cms.ts";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const { title, description, ogImage } = Astro.props;
const site = await getSiteSettings();
const tokenVars = await getDesignTokenVars();
const primaryNav = await getMenu("primary");
const footerNav = await getMenu("footer");
const tokenCss =
  Object.keys(tokenVars).length > 0
    ? `:root{${Object.entries(tokenVars).map(([k, v]) => `${k}:${v};`).join("")}}`
    : "";

const metaDescription = description || site.seoDescription || site.description || undefined;
const ogImageUrl = ogImage || site.ogImage || undefined;
const fullTitle = title === site.title ? title : `${title} · ${site.title}`;
---

<!doctype html>
<html lang={site.language}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    {metaDescription && <meta name="description" content={metaDescription} />}
    <meta name="theme-color" content={site.brandColor} />

    {/* Tokens de diseño (DTCG) como variables CSS en :root */}
    {tokenCss && <style is:inline set:html={tokenCss} />}

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.title} />
    <meta property="og:title" content={title} />
    {metaDescription && <meta property="og:description" content={metaDescription} />}
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}

    <style define:vars={{ brand: site.brandColor }}>
      :root { color-scheme: light dark; }
      body { font-family: system-ui, sans-serif; max-width: 42rem; margin: 0 auto; padding: 1rem; line-height: 1.6; }
      a { color: var(--brand); }
      .site-header { display: flex; align-items: center; gap: 1.25rem; padding: 1.25rem 0; border-bottom: 1px solid rgba(0,0,0,0.1); margin-bottom: 2rem; flex-wrap: wrap; }
      /* Menú: raíz horizontal; submenús como lista vertical indentada (sin JS). */
      .site-header :global(.nav-root) { display: flex; gap: 1rem; list-style: none; margin: 0; padding: 0; flex-wrap: wrap; }
      .site-header :global(.nav-sub), footer :global(.nav-sub) { list-style: none; margin: 0.25rem 0 0; padding-left: 0.9rem; border-left: 2px solid rgba(0,0,0,0.1); font-size: 0.9em; }
      footer :global(.nav-root) { display: flex; gap: 1rem; list-style: none; margin: 0 0 0.75rem; padding: 0; flex-wrap: wrap; }
      .site-header img { height: 34px; width: auto; }
      .site-header a { color: inherit; text-decoration: none; font-weight: 700; font-size: 1.1rem; }
      main { min-height: 40vh; }
      footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid rgba(0,0,0,0.1); font-size: 0.85rem; opacity: 0.6; }
    </style>
  </head>
  <body>
    <header class="site-header">
      <a href="/">
        {site.logoUrl && <img src={site.logoUrl} alt={site.title} />}
        <span>{site.title}</span>
      </a>
      {primaryNav && <nav aria-label="Navegación principal"><NavMenu items={primaryNav.items} /></nav>}
    </header>
    <main>
      <slot />
    </main>
    <footer>
      {footerNav && footerNav.items.length > 0 && (
        <nav aria-label="Pie de página"><NavMenu items={footerNav.items} /></nav>
      )}
      {site.description || "Renderizado por Astro (SSR) · AstroCMS"}
    </footer>
  </body>
</html>
