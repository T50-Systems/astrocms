# === CMS server ===
NODE_ENV=development
CMS_PORT=3000
# URL pública del panel/admin (para validación de origin en postMessage)
ADMIN_ORIGIN=http://localhost:3000
# URL pública del sitio Astro (para validación de origin en postMessage / preview)
PREVIEW_ORIGIN=http://localhost:4321

# === Base de datos (PostgreSQL) ===
# El compose publica Postgres en el puerto host 5433 (evita chocar con un Postgres nativo en 5432).
# Usa 127.0.0.1 (no 'localhost') para forzar IPv4 en Windows.
DATABASE_URL=postgres://astrocms:astrocms@127.0.0.1:5433/astrocms

# === Sesiones / seguridad ===
# Secreto para firmar cookies de sesión y tokens de preview (generar uno propio; NO commitear el real)
SESSION_SECRET=change-me-in-your-.env
# Duración de la sesión (segundos)
SESSION_TTL=1209600
# TTL del token de preview (segundos)
PREVIEW_TOKEN_TTL=900

# === Infra: adaptadores por puerto (ADR-0008). Defaults = 0 dependencias externas ===
# Caché (memory | redis). Sin Redis en el MVP.
CACHE_DRIVER=memory
REDIS_URL=
# Cola de tareas (inprocess | pgboss | bullmq). pgboss reutiliza la propia Postgres.
JOB_QUEUE_DRIVER=inprocess
# Correo (noop | smtp)
MAILER_DRIVER=noop
SMTP_URL=
# Proveedor de IA (none | openai | anthropic | ...). Opcional; el CMS funciona sin IA.
AI_PROVIDER=none
AI_API_KEY=

# === Storage (fs | s3 | r2 | minio | gcs) ===
STORAGE_DRIVER=fs
STORAGE_FS_ROOT=./data/uploads
# Config S3/R2/MinIO (si STORAGE_DRIVER != fs)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=astrocms
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# === Astro público ===
# Base URL de la API del CMS que consume el sitio Astro (SSR)
CMS_API_URL=http://localhost:3000/api/v1
